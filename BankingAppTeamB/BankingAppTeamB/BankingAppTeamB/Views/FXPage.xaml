<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BankingAppTeamB.Views.FXPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="10" Padding="20">

        <ComboBox Header="Source Account"
                  ItemsSource="{Binding Accounts}"
                  SelectedItem="{Binding SourceAccount, Mode=TwoWay}"
                  DisplayMemberPath="AccountName"/>

    
        <ComboBox Header="Target Account"
                  ItemsSource="{Binding Accounts}"
                  SelectedItem="{Binding TargetAccount, Mode=TwoWay}"
                  DisplayMemberPath="AccountName"/>

  
        <TextBox Header="Amount"
                 Text="{Binding AmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
    
        <TextBlock Text="Live Rate:" />
        <TextBlock Text="{Binding LiveRate}" />

        <TextBlock Text="Commission:" />
        <TextBlock Text="{Binding Commission}" />

        <TextBlock Text="Target Amount:" />
        <TextBlock Text="{Binding TargetAmount}" />

        <StackPanel Orientation="Horizontal" Spacing="10">

            <Button Content="Load Rates"
                    Command="{Binding LoadRatesCommand}" />

            <Button Content="Lock Rate"
                    Command="{Binding LockRateCommand}" />

     
            <Button Content="Execute Exchange"
                    Command="{Binding ExecuteExchangeCommand}" />
        </StackPanel>

        <TextBlock Text="Seconds Remaining:" />
        <TextBlock Text="{Binding SecondsRemaining}" />

    
        <TextBlock Text="Transaction Reference:" />
        <TextBlock Text="{Binding TransactionRef}" />

      
        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="Red" />


        <StackPanel Orientation="Horizontal" Spacing="10">

            <Button Content="Cancel"
                    Command="{Binding CancelCommand}" />

            <Button Content="New Exchange"
                    Command="{Binding NewExchangeCommand}" />
        </StackPanel>

    </StackPanel>
</Page>