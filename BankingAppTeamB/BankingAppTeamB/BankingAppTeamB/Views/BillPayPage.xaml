<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BankingAppTeamB.Views.BillPayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:BankingAppTeamB.Models"
    xmlns:converters="using:BankingAppTeamB.Converters">

    <Page.Resources>
        <converters:StepToVisibilityConverter x:Key="StepToVisibility"/>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Spacing="20" Padding="30">

            <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=1}"
                        Spacing="12">
                <TextBlock Text="Select Biller" FontSize="20" FontWeight="SemiBold"/>

                <TextBox PlaceholderText="Search..."
                         Text="{Binding SearchQuery, Mode=TwoWay}"/>

                <ComboBox PlaceholderText="Category"
                          SelectedValuePath="Content"
                          SelectedValue="{Binding SelectedCategory, Mode=TwoWay}">
                    <ComboBoxItem Content="Utilities"/>
                    <ComboBoxItem Content="Internet"/>
                    <ComboBoxItem Content="Mobile"/>
                    <ComboBoxItem Content="Insurance"/>
                    <ComboBoxItem Content="Taxes"/>
                </ComboBox>

                <Button Content="Search"
                        Command="{Binding SearchCommand}"/>

                <ListView ItemsSource="{Binding Billers}"
                          SelectedItem="{Binding SelectedBiller, Mode=TwoWay}"
                          MaxHeight="300">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Biller">
                            <TextBlock Text="{x:Bind Name}"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Red"
                           TextWrapping="Wrap"/>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Next"
                            Command="{Binding NextStepCommand}"/>

                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=2}"
                        Spacing="12">
                <TextBlock Text="Payment Details" FontSize="20" FontWeight="SemiBold"/>

                <CheckBox Content="Pay in full"
                          IsChecked="{Binding IsPayInFull, Mode=TwoWay}"/>

                <TextBox Header="Reference"
                         Text="{Binding BillerReference, Mode=TwoWay}"
                         Visibility="{Binding IsPayInFull, Converter={StaticResource InverseBoolToVisibility}}"/>

                <NumberBox x:Name="AmountBox"
                           Header="Amount"
                           Minimum="0"
                           SmallChange="1"
                           SpinButtonPlacementMode="Compact"
                           ValueChanged="AmountBox_ValueChanged"/>

                <TextBlock Text="Select Source Account"/>

                <ComboBox ItemsSource="{Binding Accounts}"
                          SelectedItem="{Binding SelectedAccount, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Account">
                            <StackPanel>
                                <TextBlock Text="{x:Bind IBAN}"/>
                                <TextBlock Text="{x:Bind AccountName}" FontSize="12" Opacity="0.7"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Red"
                           TextWrapping="Wrap"/>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Next"
                            Command="{Binding NextStepCommand}"/>

                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=3}"
            Spacing="10">

                <TextBlock Text="Confirm Payment" FontSize="20" FontWeight="SemiBold"/>

                <TextBlock Text="Biller:" FontWeight="Bold"/>
                <TextBlock Text="{Binding SelectedBiller.Name}"/>

                <TextBlock Text="Amount:" FontWeight="Bold"/>
                <TextBlock Text="{Binding Amount}"/>

                <TextBlock Text="Fee:" FontWeight="Bold"/>
                <TextBlock Text="{Binding Fee}"/>

                <TextBlock Text="From Account:" FontWeight="Bold"/>
                <TextBlock Text="{Binding SelectedAccount.IBAN}"/>

                <TextBlock Text="{Binding ErrorMessage}"
               Foreground="Red"
               TextWrapping="Wrap"/>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Pay"
                Command="{Binding PayBillCommand}"/>

                    <Button Content="Cancel"
                Command="{Binding CancelCommand}"/>
                </StackPanel>

            </StackPanel>

            <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepToVisibility}, ConverterParameter=4}"
                        Spacing="12">
                <TextBlock Text="Payment Successful!" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding ReceiptNumber}" FontSize="18"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>