<Page
    x:Class="BankingAppTeamB.Views.TransferPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:BankingAppTeamB.Converters">

    <Page.Resources>
        <converters:StepToVisibilityConverter x:Key="StepToVisibility"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </Page.Resources>

    <ScrollViewer Padding="40">
        <StackPanel MaxWidth="520" HorizontalAlignment="Center" Spacing="24">

            <TextBlock
                Text="Transfer"
                FontSize="28"
                FontWeight="SemiBold"/>

            <InfoBar
                IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                Severity="Error"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"/>

            <StackPanel
                Spacing="16"
                Visibility="{x:Bind ViewModel.CurrentStep,
                             Mode=OneWay,
                             Converter={StaticResource StepToVisibility},
                             ConverterParameter=1}">

                <TextBlock
                    Text="Step 1 of 4 — Select source account"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <TextBlock Text="Source account" FontSize="13"/>
                <ComboBox
                    ItemsSource="{x:Bind ViewModel.Accounts, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedAccount, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"
                    PlaceholderText="Select an account">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding AccountName}"/>
                                <TextBlock
                                    Text="{Binding Currency}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Button
                    Content="Next"
                    Command="{x:Bind ViewModel.NextStepCommand}"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource AccentButtonStyle}"/>

            </StackPanel>

            <StackPanel
                Spacing="16"
                Visibility="{x:Bind ViewModel.CurrentStep,
                             Mode=OneWay,
                             Converter={StaticResource StepToVisibility},
                             ConverterParameter=2}">

                <TextBlock
                    Text="Step 2 of 4 — Recipient details"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <TextBlock Text="Recipient name" FontSize="13"/>
                <TextBox
                    Text="{x:Bind ViewModel.RecipientName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="e.g. John Smith"/>

                <TextBlock Text="Recipient IBAN" FontSize="13"/>
                <TextBox
                    Text="{x:Bind ViewModel.RecipientIBAN, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="e.g. RO49AAAA1B31007593840000"/>

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8"
                    Visibility="{x:Bind ViewModel.IsIBANValid, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock
                        Text="Bank:"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        FontSize="13"/>
                    <TextBlock
                        Text="{x:Bind ViewModel.BankName, Mode=OneWay}"
                        FontSize="13"
                        Foreground="Green"/>
                </StackPanel>

                <TextBlock
                    Text="Invalid IBAN. Please check the format."
                    Foreground="Red"
                    FontSize="13"
                    Visibility="{x:Bind ViewModel.IsIBANValid,
                                 Mode=OneWay,
                                 Converter={StaticResource InverseBoolToVisibility}}"/>

                <Button
                    Content="Next"
                    Command="{x:Bind ViewModel.NextStepCommand}"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource AccentButtonStyle}"/>

            </StackPanel>

            <StackPanel
                Spacing="16"
                Visibility="{x:Bind ViewModel.CurrentStep,
                             Mode=OneWay,
                             Converter={StaticResource StepToVisibility},
                             ConverterParameter=3}">

                <TextBlock
                    Text="Step 3 of 4 — Amount and currency"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <TextBlock Text="Amount" FontSize="13"/>
                <TextBox
                    Text="{x:Bind ViewModel.AmountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="e.g. 100"/>

                <TextBlock Text="Currency" FontSize="13"/>
                <ComboBox
                    SelectedItem="{x:Bind ViewModel.Currency, Mode=TwoWay}"
                    HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="EUR"/>
                    <ComboBoxItem Content="USD"/>
                    <ComboBoxItem Content="RON"/>
                </ComboBox>

                <TextBlock
                    Text="{x:Bind ViewModel.FxPreviewText, Mode=OneWay}"
                    FontSize="13"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Visibility="{x:Bind ViewModel.FxPreviewText, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                <Button
                    Content="Next"
                    Command="{x:Bind ViewModel.NextStepCommand}"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource AccentButtonStyle}"/>

            </StackPanel>

            <StackPanel
                Spacing="16"
                Visibility="{x:Bind ViewModel.CurrentStep,
                             Mode=OneWay,
                             Converter={StaticResource StepToVisibility},
                             ConverterParameter=4}">

                <TextBlock
                    Text="Step 4 of 4 — Review and confirm"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="From:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
                        <TextBlock Text="{x:Bind ViewModel.SelectedAccount.AccountName, Mode=OneWay}" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="To:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
                        <TextBlock Text="{x:Bind ViewModel.RecipientName, Mode=OneWay}" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="IBAN:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
                        <TextBlock Text="{x:Bind ViewModel.RecipientIBAN, Mode=OneWay}" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Bank:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
                        <TextBlock Text="{x:Bind ViewModel.BankName, Mode=OneWay}" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Amount:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
                        <TextBlock Text="{x:Bind ViewModel.AmountText, Mode=OneWay}" FontSize="13"/>
                        <TextBlock Text="{x:Bind ViewModel.Currency, Mode=OneWay}" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="FX Preview:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
                        <TextBlock Text="{x:Bind ViewModel.FxPreviewText, Mode=OneWay}" FontSize="13"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    Spacing="8"
                    Visibility="{x:Bind ViewModel.Requires2FA, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock
                        Text="Transfers of 1000 or more require 2FA confirmation."
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="2FA Token" FontSize="13"/>
                    <TextBox
                        Text="{x:Bind ViewModel.TwoFAToken, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Enter your 2FA token"/>
                </StackPanel>

                <TextBlock
                    Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    Foreground="Red"
                    FontSize="13"
                    Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>

                <Button
                    Content="Confirm Transfer"
                    Command="{x:Bind ViewModel.TransferCommand}"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource AccentButtonStyle}"/>

            </StackPanel>

            <StackPanel
                Spacing="16"
                HorizontalAlignment="Center"
                Visibility="{x:Bind ViewModel.CurrentStep,
                             Mode=OneWay,
                             Converter={StaticResource StepToVisibility},
                             ConverterParameter=5}">

                <ProgressRing IsActive="True" Width="48" Height="48"/>
                <TextBlock
                    Text="Processing your transfer..."
                    FontSize="14"
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            </StackPanel>

            <StackPanel
                Spacing="16"
                HorizontalAlignment="Center"
                Visibility="{x:Bind ViewModel.CurrentStep,
                             Mode=OneWay,
                             Converter={StaticResource StepToVisibility},
                             ConverterParameter=6}">

                <TextBlock
                    Text="Transfer Successful!"
                    FontSize="22"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <TextBlock
                        Text="Reference:"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        FontSize="14"/>
                    <TextBlock
                        Text="{x:Bind ViewModel.TransactionRef, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="SemiBold"/>
                </StackPanel>

                <Button
                    Content="Send Again"
                    Command="{x:Bind ViewModel.SendAgainCommand}"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource AccentButtonStyle}"/>

                <Button
                    Content="Back to Home"
                    Command="{x:Bind ViewModel.CancelCommand}"
                    HorizontalAlignment="Stretch"/>

            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
