<Page
    x:Class="BankingAppTeamB.Views.TransferPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:BankingAppTeamB.Converters"
    xmlns:models="using:BankingAppTeamB.Models">

    <Page.Resources>
        <converters:StepToVisibilityConverter x:Key="StepToVisibility"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </Page.Resources>

    <ScrollViewer Padding="40">
        <StackPanel MaxWidth="520" HorizontalAlignment="Center" Spacing="32">

            <!-- Page Title -->
            <TextBlock Text="Transfer" FontSize="28" FontWeight="SemiBold" 
                       HorizontalAlignment="Center"/>

            <!-- Error InfoBar -->
            <InfoBar
                IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                Severity="Error"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"/>

            <!-- STEP 1: Select Account -->
            <StackPanel Spacing="16"
                        Visibility="{x:Bind ViewModel.CurrentStep, Mode=OneWay,
                                     Converter={StaticResource StepToVisibility}, ConverterParameter=1}">
                <TextBlock Text="Step 1 of 4 — Select source account" 
                           FontSize="16" FontWeight="SemiBold" 
                           HorizontalAlignment="Center"/>
                <ComboBox ItemsSource="{x:Bind ViewModel.Accounts}"
                          SelectedItem="{x:Bind ViewModel.SelectedAccount, Mode=TwoWay}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Account">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind AccountName}"/>
                                <TextBlock Text="{x:Bind Currency}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="Next" Command="{x:Bind ViewModel.NextStepCommand}" 
                        HorizontalAlignment="Center" Width="150"/>
            </StackPanel>

            <!-- STEP 2: Recipient Info -->
            <StackPanel Spacing="16"
                        Visibility="{x:Bind ViewModel.CurrentStep, Mode=OneWay,
                                     Converter={StaticResource StepToVisibility}, ConverterParameter=2}">
                <TextBlock Text="Step 2 of 4 — Recipient Information" 
                           FontSize="16" FontWeight="SemiBold" 
                           HorizontalAlignment="Center"/>
                <TextBox Header="Recipient Name" Text="{x:Bind ViewModel.RecipientName, Mode=TwoWay}"/>
                <TextBox Header="Recipient IBAN" Text="{x:Bind ViewModel.RecipientIBAN, Mode=TwoWay}"/>
                <TextBlock Text="{x:Bind ViewModel.BankName, Mode=OneWay}"/>
                <Button Content="Next" Command="{x:Bind ViewModel.NextStepCommand}" 
                        HorizontalAlignment="Center" Width="150"/>
            </StackPanel>

            <!-- STEP 3: Amount -->
            <StackPanel Spacing="16"
                        Visibility="{x:Bind ViewModel.CurrentStep, Mode=OneWay,
                                     Converter={StaticResource StepToVisibility}, ConverterParameter=3}">
                <TextBlock Text="Step 3 of 4 — Enter Amount" 
                           FontSize="16" FontWeight="SemiBold" 
                           HorizontalAlignment="Center"/>
                <TextBox Header="Amount" Text="{x:Bind ViewModel.AmountText, Mode=TwoWay}"/>
                <ComboBox SelectedValue="{x:Bind ViewModel.Currency, Mode=TwoWay}"
                          SelectedValuePath="Content">
                    <ComboBoxItem Content="EUR"/>
                    <ComboBoxItem Content="USD"/>
                    <ComboBoxItem Content="RON"/>
                </ComboBox>
                <TextBlock Text="{x:Bind ViewModel.FxPreviewText, Mode=OneWay}"/>
                <Button Content="Next" Command="{x:Bind ViewModel.NextStepCommand}" 
                        HorizontalAlignment="Center" Width="150"/>
            </StackPanel>

            <!-- STEP 4: 2FA Confirmation -->
            <StackPanel Spacing="16"
                        Visibility="{x:Bind ViewModel.CurrentStep, Mode=OneWay,
                                     Converter={StaticResource StepToVisibility}, ConverterParameter=4}">
                <TextBlock Text="Step 4 of 4 — 2FA Confirmation" 
                           FontSize="16" FontWeight="SemiBold" 
                           HorizontalAlignment="Center"/>
                <CheckBox Content="I confirm this transaction"
                          IsChecked="{x:Bind ViewModel.Is2FAConfirmed, Mode=TwoWay}"
                          HorizontalAlignment="Center"/>
                <Button Content="Next"
                        Command="{x:Bind ViewModel.NextStepCommand}"
                        IsEnabled="{x:Bind ViewModel.Is2FAConfirmed, Mode=OneWay}"
                        HorizontalAlignment="Center" Width="150"/>
            </StackPanel>

            <!-- STEP 5: Confirm Transfer -->
            <StackPanel Spacing="16"
                        Visibility="{x:Bind ViewModel.CurrentStep, Mode=OneWay,
                                     Converter={StaticResource StepToVisibility}, ConverterParameter=5}">
                <TextBlock Text="Confirm Transfer" FontSize="16" FontWeight="SemiBold" 
                           HorizontalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="From:" FontWeight="Bold"/>
                    <TextBlock Text="{x:Bind ViewModel.SelectedAccount.AccountName, Mode=OneWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="To:" FontWeight="Bold"/>
                    <TextBlock Text="{x:Bind ViewModel.RecipientName, Mode=OneWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Amount:" FontWeight="Bold"/>
                    <TextBlock Text="{x:Bind ViewModel.AmountText, Mode=OneWay}"/>
                    <TextBlock Text="{x:Bind ViewModel.Currency, Mode=OneWay}"/>
                </StackPanel>
                <Button Content="Confirm Transfer" Command="{x:Bind ViewModel.TransferCommand}" 
                        HorizontalAlignment="Center" Width="200"/>
            </StackPanel>

            <!-- STEP 6: Success / Receipt -->
            <StackPanel Spacing="16"
                        Visibility="{x:Bind ViewModel.CurrentStep, Mode=OneWay,
                                     Converter={StaticResource StepToVisibility}, ConverterParameter=6}">
                <TextBlock Text="Transfer Successful!" FontSize="20" FontWeight="SemiBold" 
                           HorizontalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="To:" FontWeight="Bold"/>
                    <TextBlock Text="{x:Bind ViewModel.RecipientName, Mode=OneWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="IBAN:" FontWeight="Bold"/>
                    <TextBlock Text="{x:Bind ViewModel.RecipientIBAN, Mode=OneWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Reference:" FontWeight="Bold"/>
                    <TextBlock Text="{x:Bind ViewModel.TransactionRef, Mode=OneWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Amount:" FontWeight="Bold"/>
                    <TextBlock Text="{x:Bind ViewModel.AmountText, Mode=OneWay}"/>
                    <TextBlock Text="{x:Bind ViewModel.Currency, Mode=OneWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="From:" FontWeight="Bold"/>
                    <TextBlock Text="{x:Bind ViewModel.SelectedAccount.AccountName, Mode=OneWay}"/>
                </StackPanel>
                <Button Content="New Transfer" Command="{x:Bind ViewModel.SendAgainCommand}" 
                        HorizontalAlignment="Center" Width="200"/>
            </StackPanel>

            <!-- STEP 7: Error -->
            <StackPanel Spacing="16"
             Visibility="{x:Bind ViewModel.CurrentStep, Mode=OneWay,
                 Converter={StaticResource StepToVisibility}, ConverterParameter=7}">

                <TextBlock Text="Error"
               FontSize="18"
               FontWeight="SemiBold"
               HorizontalAlignment="Center"/>

                <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
               TextAlignment="Center"
               TextWrapping="Wrap"/>

                <Button Content="Start Again"
            Command="{x:Bind ViewModel.SendAgainCommand}"
            HorizontalAlignment="Center"
            Width="200"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>