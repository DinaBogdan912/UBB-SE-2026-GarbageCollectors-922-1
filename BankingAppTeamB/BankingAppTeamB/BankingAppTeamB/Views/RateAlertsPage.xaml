<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BankingAppTeamB.Views.RateAlertsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BankingAppTeamB.Views"
    xmlns:converters="using:BankingAppTeamB.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    x:Name="RootPage">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <Grid Margin="0,0,0,12">
                <TextBlock Text="Live Rates" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left" />
                <Button Content="Refresh" Command="{Binding RefreshRatesCommand}" VerticalAlignment="Center" HorizontalAlignment="Right" />
            </Grid>

            <ItemsControl ItemsSource="{Binding LiveRates}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4" ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Key}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="{Binding Value, Converter={StaticResource DecimalFormat}}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="My Alerts" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />

            <ListView Grid.Row="1" ItemsSource="{Binding Alerts}" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12" Margin="0,4" BorderBrush="Gray" BorderThickness="1" CornerRadius="4">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding BaseCurrency}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="➔" VerticalAlignment="Center" Foreground="Gray"/>
                                <TextBlock Grid.Column="2" Text="{Binding TargetCurrency}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="3" Text="{Binding TargetRate}" FontWeight="Bold" VerticalAlignment="Center" />

                                <Border Grid.Column="4" Background="#44FF0000" CornerRadius="4" Padding="8,4" 
                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                        Visibility="{Binding IsTriggered, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="TRIGGERED" Foreground="Red" FontWeight="Bold" FontSize="12"/>
                                </Border>

                                <Button Grid.Column="5" Content="Delete" 
                                        Command="{Binding DataContext.DeleteAlertCommand, ElementName=RootPage}" 
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="16" Margin="0,0,0,16">
            <TextBox Header="Base Currency" 
                     Text="{Binding BaseCurrency, Mode=TwoWay}" 
                     PlaceholderText="e.g. USD" Width="150" />

            <TextBox Header="Target Currency" 
                     Text="{Binding TargetCurrency, Mode=TwoWay}" 
                     PlaceholderText="e.g. EUR" Width="150" />

            <TextBox Header="Target Rate" 
                     Text="{Binding TargetRateText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     PlaceholderText="e.g. 1.05" Width="150" />

            <Button Content="Create Alert" Command="{Binding CreateAlertCommand}" VerticalAlignment="Bottom" />
        </StackPanel>

        <TextBlock Grid.Row="3" 
                   Text="{Binding ErrorMessage}" 
                   Foreground="Red" FontWeight="Bold" />
    </Grid>
</Page>